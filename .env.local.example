# ─── WordPress / WPGraphQL ────────────────────────────────────────────────────
# Full URL to your WPGraphQL endpoint (e.g. https://yourdomain.com/graphql)
WP_GRAPHQL_URL=https://yourdomain.com/graphql

# Base URL of your WordPress site (used for image remotePatterns in next.config.js)
WP_SITE_URL=https://yourdomain.com

# ─── ISR Webhook (On-demand Revalidation) ────────────────────────────────────
# Generate a strong random string: openssl rand -base64 32
# Must match the secret configured in WP Webhooks plugin
REVALIDATE_SECRET=your-strong-random-secret-here

# ─── JWT Auth (Subscriber-Gated Content) ─────────────────────────────────────
# Must match the JWT_AUTH_SECRET_KEY constant in your wp-config.php
WP_JWT_AUTH_SECRET=your-jwt-secret-here

# ─── Newsletter (Mailchimp) ───────────────────────────────────────────────────
MAILCHIMP_API_KEY=
MAILCHIMP_AUDIENCE_ID=
# Your Mailchimp data center prefix (e.g. us1, us21)
MAILCHIMP_SERVER_PREFIX=us1

# ─── WPGraphQL Plugin Feature Flags ──────────────────────────────────────────
# Set to "true" once the corresponding WP plugin is installed & active
NEXT_PUBLIC_YOAST_WPGRAPHQL=false
NEXT_PUBLIC_ACF_WPGRAPHQL=false

# ─── Google AdSense ───────────────────────────────────────────────────────────
# Your publisher ID from Google AdSense (ca-pub-XXXXXXXXXX)
NEXT_PUBLIC_ADSENSE_PUB_ID=ca-pub-XXXXXXXXXX

# ─── Push Notifications ───────────────────────────────────────────────────────
NEXT_PUBLIC_ONESIGNAL_APP_ID=
NEXT_PUBLIC_WEBPUSHR_KEY=

# ─── Site URL (for sitemap generation) ───────────────────────────────────────
SITE_URL=https://yourdomain.com

# ─── Akismet (Comment Spam Protection) ───────────────────────────────────────
AKISMET_API_KEY=
